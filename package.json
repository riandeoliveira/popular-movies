  "author": {
    "name": "Rian Oliveira",
    "email": "riandiasdeoliveira2001@gmail.com"
  },
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite --open",
    "eslint": "next lint",
    "format": "prettier --write src/**/*.{ts,tsx} vite.config.ts",
    "lint": "eslint --fix src/**/*.{ts,tsx} vite.config.ts",
    "start": "vite preview --open"
  },
  "dependencies": {
